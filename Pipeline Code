"""Geospatial time-series pipeline for Sentinel-2 and Landsat data."""

from __future__ import annotations

import argparse
from pathlib import Path

import numpy as np
import pandas as pd
import rasterio
import xarray as xr
import yaml
from odc.stac import load
from pystac_client import Client


def load_config(path: str) -> dict:
    with open(path, "r", encoding="utf-8") as f:
        return yaml.safe_load(f)


def stac_search(url: str, collection: str, bbox: list[float], time_range: str, cloud_max: int):
    client = Client.open(url)
    search = client.search(
        collections=[collection],
        bbox=bbox,
        datetime=time_range,
        query={"eo:cloud_cover": {"lt": cloud_max}},
    )
    return list(search.items())


def compute_ndvi(red: xr.DataArray, nir: xr.DataArray) -> xr.DataArray:
    ndvi = (nir - red) / (nir + red + 1e-6)
    return ndvi.clip(min=-1, max=1)


def save_dataarray_to_geotiff(da: xr.DataArray, out_path: Path):
    out_path.parent.mkdir(parents=True, exist_ok=True)
    data = da.values.astype("float32")

    transform = rasterio.transform.from_bounds(
        float(da.x.min()),
        float(da.y.min()),
        float(da.x.max()),
        float(da.y.max()),
        da.shape[1],
        da.shape[0],
    )

    with rasterio.open(
        out_path,
        "w",
        driver="GTiff",
        height=data.shape[0],
        width=data.shape[1],
        count=1,
        dtype="float32",
        crs="EPSG:4326",
        transform=transform,
        compress="deflate",
    ) as dst:
        dst.write(data, 1)


def run_pipeline(config: dict):
    output_dir = Path(config["output_dir"])
    output_dir.mkdir(parents=True, exist_ok=True)

    # Example bbox; replace with AOI-derived bbox in production.
    bbox = [-125.0, 24.0, -66.0, 49.0]
    time_range = f"{config['start_date']}/{config['end_date']}"
    cloud_max = int(config["cloud_cover_max"])

    s2_items = stac_search(
        url=config["stac"]["sentinel2_url"],
        collection=config["collections"]["sentinel2"],
        bbox=bbox,
        time_range=time_range,
        cloud_max=cloud_max,
    )

    ls_items = stac_search(
        url=config["stac"]["landsat_url"],
        collection=config["collections"]["landsat"],
        bbox=bbox,
        time_range=time_range,
        cloud_max=cloud_max,
    )

    items = s2_items + ls_items
    if not items:
        raise RuntimeError("No imagery items found. Broaden date range or cloud threshold.")

    dataset = load(
        items,
        chunks={},
        crs=config["analysis"]["target_crs"],
        resolution=float(config["analysis"]["resolution"]),
        bands=["red", "nir"],
    )

    ndvi = compute_ndvi(dataset["red"], dataset["nir"]).rename("ndvi")

    scene_dir = output_dir / "scene_ndvi"
    records = []

    for idx in range(ndvi.sizes["time"]):
        timestamp = pd.to_datetime(ndvi.time.values[idx])
        scene = ndvi.isel(time=idx)
        scene_out = scene_dir / f"ndvi_{timestamp:%Y%m%d}.tif"
        save_dataarray_to_geotiff(scene, scene_out)

    monthly = ndvi.resample(time="1MS").median()
    monthly_dir = output_dir / "monthly_ndvi"
    for idx in range(monthly.sizes["time"]):
        timestamp = pd.to_datetime(monthly.time.values[idx])
        arr = monthly.isel(time=idx)
        out = monthly_dir / f"ndvi_monthly_{timestamp:%Y%m}.tif"
        save_dataarray_to_geotiff(arr, out)

        vals = arr.values
        records.append(
            {
                "month": f"{timestamp:%Y-%m}",
                "mean_ndvi": float(np.nanmean(vals)),
                "median_ndvi": float(np.nanmedian(vals)),
                "p10_ndvi": float(np.nanpercentile(vals, 10)),
                "p90_ndvi": float(np.nanpercentile(vals, 90)),
            }
        )

    summary = pd.DataFrame(records)
    summary.to_csv(output_dir / "monthly_ndvi_summary.csv", index=False)


def main():
    parser = argparse.ArgumentParser(description="Run Sentinel-2/Landsat NDVI time-series pipeline")
    parser.add_argument("--config", required=True, help="Path to YAML config")
    args = parser.parse_args()

    config = load_config(args.config)
    run_pipeline(config)


if __name__ == "__main__":
    main()
